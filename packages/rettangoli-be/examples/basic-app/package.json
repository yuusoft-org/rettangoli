{
  "name": "@rettangoli-be-example/basic-app",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Design example app for rettangoli-be",
  "scripts": {
    "check": "node ./scripts/be-cli.js check",
    "build": "node ./scripts/be-cli.js build",
    "manifest": "node ./scripts/be-cli.js manifest",
    "verify": "node ./scripts/be-cli.js verify --json",
    "test:examples": "bunx vitest run --reporter=verbose --config vitest.config.js",
    "test:method": "node ./scripts/be-cli.js test --method health.ping",
    "test:e2e": "node ./scripts/be-cli.js build && node --test ./test/e2e/*.e2e.js"
  }
}
